{
  "mcpServers": {
    "cross-session-memory-bridge": {
      "cwd": ".",
      "command": "node",
      "args": [
        "./runtime/launch-mcp.mjs"
      ],
      "env": {
        "CSM_DATABASE_PROVIDER": "postgres",
        "CSM_REQUIRE_EXPLICIT_DATABASE_URL": "true"
      },
      "env_vars": [
        "CSM_DATABASE_URL",
        "CSM_DB_TLS_MODE",
        "CSM_EMBEDDING_PROVIDER",
        "CSM_EMBEDDING_DIMENSIONS",
        "OLLAMA_HOST",
        "OPENAI_API_KEY"
      ]
    }
  }
}
