{
  "name": "opencode-cross-session-memory",
  "version": "1.0.0",
  "description": "Cross-session memory plugin for opencode - Persistent memory across conversations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./codex-bridge": {
      "import": "./dist/codex-bridge.js",
      "types": "./dist/codex-bridge.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    },
    "./database": {
      "import": "./dist/database.js",
      "types": "./dist/database.d.ts"
    },
    "./embeddings": {
      "import": "./dist/embeddings.js",
      "types": "./dist/embeddings.d.ts"
    },
    "./memory-manager": {
      "import": "./dist/memory-manager.js",
      "types": "./dist/memory-manager.d.ts"
    },
    "./context-governor": {
      "import": "./dist/context-governor.js",
      "types": "./dist/context-governor.d.ts"
    },
    "./redactor": {
      "import": "./dist/redactor.js",
      "types": "./dist/redactor.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "tui": "dist/tui.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test test/*.test.ts",
    "verify": "npm run build && npm run typecheck && npx tsx --test test/*.test.ts",
    "benchmark:long-session": "npx tsx src/benchmark.ts",
    "lint": "npm run lint:src",
    "lint:src": "eslint src --max-warnings=102",
    "lint:all": "eslint .",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.17.0",
    "better-sqlite3": "^12.11.1",
    "pg": "^8.13.0",
    "pgvector": "^0.3.0"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.1.0",
    "@opentui/solid": ">=0.1.0",
    "solid-js": "^1.9.13"
  },
  "peerDependenciesMeta": {
    "@opentui/solid": {
      "optional": true
    },
    "@opentui/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1"
  },
  "overrides": {
    "@opencode-ai/plugin": "1.17.0"
  }
}
