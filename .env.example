# Cross-Session Memory Plugin Configuration

# Database Backend: postgres (default) or sqlite
CSM_DATABASE_PROVIDER=postgres

# PostgreSQL Connection (only used when CSM_DATABASE_PROVIDER=postgres)
# Development: defaults to localhost if not set
# Production: set this explicitly for security
CSM_DATABASE_URL=postgresql://localhost:5432/opencode_memory
# CSM_REQUIRE_EXPLICIT_DATABASE_URL=true

# SQLite Database File (only used when CSM_DATABASE_PROVIDER=sqlite)
# Default: .data/csm-memory.db
# CSM_SQLITE_PATH=.data/csm-memory.db

# Embedding Provider Configuration
# Options: ollama, openai
CSM_EMBEDDING_PROVIDER=ollama

# OpenAI Embeddings (only required if provider=openai)
# The ecosystem standard - don't invent a new env var
OPENAI_API_KEY=your-openai-api-key-here

# Ollama Embeddings (only required if provider=ollama)
# Defaults to http://localhost:11434 if not set
OLLAMA_HOST=http://localhost:11434

# Workspace Root (optional, for redactor)
# If set, redactor will use this as workspace root
# CSM_WORKSPACE_ROOT=/path/to/workspace

# Other Configuration (all have defaults)
# CSM_MAX_MEMORIES_PER_RECALL=10
# CSM_IMPORTANCE_THRESHOLD=0.3
# CSM_AUTO_STORE_CONVERSATIONS=true
# CSM_FULL_TRANSCRIPTS=true
# CSM_CONTEXT_RECALL_INTERVAL=90
# CSM_SUBCONSCIOUS_WATCH_INTERVAL=30
# CSM_GIT_POLL_INTERVAL=60
# CSM_CONTEXT_PRESSURE_RECOMMEND=0.65
# CSM_CONTEXT_PRESSURE_DEMAND=0.85
# CSM_LOOP_DETECTION_THRESHOLD=3
# CSM_LOG_TOOL_USAGE=false
# CSM_LOG_COMMANDS=false
# CSM_LOG_SESSION_LIFECYCLE=false
# CSM_FILTER_BUILD_ARTIFACTS=true
# CSM_PROMPT_DEBUG=false

# Re-entry Onboarding (Phase 8B)
# When a new session starts, build a context block from prior CSM state.
# live injection (default): block is injected once on the first turn.
# Set CSM_REENTRY_PREVIEW_ONLY=true only when explicitly testing preview behavior.
# CSM_REENTRY_ENABLED=true
# CSM_REENTRY_PREVIEW_ONLY=false
# CSM_REENTRY_MAX_CHARS=2100
# CSM_REENTRY_MIN_LAYER_CHARS=50
